<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<appSettings>
		<!-- Database Configuration -->
		<add key="ConnectionString" value="Data Source=localhost;Initial Catalog=DB_NilaiMahasiswa;Integrated Security=true;" />

		<!-- Application Settings -->
		<add key="AppName" value="Sistem Pengolahan Nilai Mahasiswa" />
		<add key="AppVersion" value="1.0" />
		<add key="CompanyName" value="Universitas Indonesia" />
		<add key="LogFilePath" value="C:\Logs\" />

		<!-- Session Settings -->
		<add key="SessionTimeout" value="30" />
		<add key="MaxLoginAttempts" value="3" />
	</appSettings>

	<system.net>
		<defaultProxy useDefaultCredentials="true" />
	</system.net>

</configuration>